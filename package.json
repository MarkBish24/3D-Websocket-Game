{
  "name": "3d-websocket-game",
  "version": "1.0.1",
  "description": "This is a websocket game with a tech stack of Vue, Express, Node, and Postgres SQL",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspace=client",
    "version:patch": "npm version patch --workspaces --include-workspace-root",
    "version:minor": "npm version minor --workspaces --include-workspace-root",
    "version:major": "npm version major --workspaces --include-workspace-root",
    "postversion": "git push --follow-tags"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarkBish24/3D-Websocket-Game.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/MarkBish24/3D-Websocket-Game/issues"
  },
  "homepage": "https://github.com/MarkBish24/3D-Websocket-Game#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
